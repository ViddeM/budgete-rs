DATABASE_URL=postgres://budgete:budgete@localhost:5432/budgete?sslmode=disable

# OAuth 2.0 — fill in with values from your identity provider (required)
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_AUTH_URL=https://provider.example.com/oauth/authorize
OAUTH_TOKEN_URL=https://provider.example.com/oauth/token
OAUTH_USERINFO_URL=https://provider.example.com/userinfo
OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/callback

# OAuth 2.0 — optional, defaults shown
# OAUTH_SCOPES=openid email profile
# OAUTH_PROVIDER_NAME=oauth

# Session duration in hours (default: 720 = 30 days)
# SESSION_DURATION_HOURS=720
